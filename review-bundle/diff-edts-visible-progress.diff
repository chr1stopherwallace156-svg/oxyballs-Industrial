+  width: 100%;
+  margin: 10px 0;
+  accent-color: var(--accent);
+}
+
+.timeline-steps {
+  display: flex;
+  gap: 4px;
+  overflow-x: auto;
+  padding-bottom: 4px;
+}
+
+.timeline-steps button {
+  flex: 0 0 auto;
+  font-size: 0.62rem;
+  color: var(--muted);
+  background: transparent;
+  border: 1px solid var(--line);
+  padding: 4px 8px;
+  cursor: pointer;
+  max-width: 140px;
+  white-space: nowrap;
+  overflow: hidden;
+  text-overflow: ellipsis;
+}
+
+.timeline-steps button span {
+  display: block;
+  font-family: var(--font-mono);
+  color: var(--accent);
+  font-size: 0.55rem;
+}
+
+.timeline-steps button.active {
+  border-color: var(--accent);
+  color: var(--ink);
+  background: rgba(47, 158, 216, 0.15);
+}
+
+.timeline-note {
+  margin-top: 8px;
+  padding-top: 8px;
+  border-top: 1px solid rgba(120, 170, 200, 0.12);
+}
+
+.timeline-note strong {
+  font-size: 0.78rem;
+}
+
+.sim-panel {
+  position: absolute;
+  z-index: 6;
+  left: calc(var(--tool-w) + 16px);
+  top: 56px;
+  width: min(340px, calc(100vw - var(--tool-w) - var(--panel-w) - 48px));
+  padding: 12px 14px;
+  background: rgba(4, 10, 16, 0.92);
+  border: 1px solid rgba(239, 68, 68, 0.35);
+}
+
+.sim-panel strong {
+  display: block;
+  font-size: 0.82rem;
+}
+
+.sim-status {
+  display: inline-block;
+  margin: 6px 0;
+  font-family: var(--font-mono);
+  font-size: 0.62rem;
+  color: #fca5a5;
+  border: 1px solid rgba(239, 68, 68, 0.4);
+  padding: 2px 6px;
+}
+
+.sim-panel p {
+  margin: 0 0 8px;
+  font-size: 0.72rem;
+  color: var(--muted);
+  line-height: 1.4;
+}
+
+.sim-panel dl {
+  margin: 0 0 8px;
+  display: grid;
+  gap: 6px;
+}
+
+.sim-panel dl > div {
+  display: flex;
+  justify-content: space-between;
+  font-size: 0.78rem;
+  border-bottom: 1px solid rgba(120, 170, 200, 0.1);
+  padding-bottom: 4px;
+}
+
+.sim-panel dt {
+  color: var(--muted);
+}
+
+.sim-panel dd {
+  margin: 0;
+  font-family: var(--font-mono);
+  color: #fca5a5;
+}
+
+.heatmap-legend {
+  position: absolute;
+  z-index: 5;
+  top: 52px;
+  left: calc(var(--tool-w) + 16px);
+  right: calc(var(--panel-w) + 16px);
+  display: flex;
+  flex-wrap: wrap;
+  gap: 6px;
+  justify-content: flex-end;
+  pointer-events: none;
+}
+
+.hm-swatch {
+  font-family: var(--font-mono);
+  font-size: 0.55rem;
+  letter-spacing: 0.03em;
+  color: #0a0a0a;
+  padding: 3px 7px;
+  font-weight: 600;
+}
+
+.config-lock-overlay.quiet,
+.honesty-strip.quiet {
+  opacity: 0.35;
+  transition: opacity 0.25s ease;
+}
+
+.config-lock-overlay,
+.honesty-strip {
+  transition: opacity 0.25s ease;
+}
+
+.app.minimal .legend {
+  display: none;
+}
+
+.app[data-mode='HEATMAP'] .honesty-strip {
+  display: none;
+}
+
+/* —— R2 Apple-style floating chrome —— */
+.floating-chrome {
+  position: absolute;
+  z-index: 8;
+  top: 14px;
+  left: calc(var(--tool-w) + 16px);
+  right: calc(var(--panel-w) + 16px);
+  display: flex;
+  justify-content: space-between;
+  gap: 12px;
+  pointer-events: none;
+}
+
+.floating-chrome > * {
+  pointer-events: auto;
+}
+
+.search-bar.pill input {
+  border-radius: 999px;
+  background: rgba(8, 18, 28, 0.72);
+  backdrop-filter: blur(12px);
+  border: 1px solid rgba(148, 163, 184, 0.25);
+  padding: 10px 16px;
+  min-width: 280px;
+  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.35);
+}
+
+.floating-actions {
+  display: flex;
+  align-items: center;
+  gap: 10px;
+  padding: 6px 10px;
+  border-radius: 999px;
+  background: rgba(8, 18, 28, 0.72);
+  backdrop-filter: blur(12px);
+  border: 1px solid rgba(148, 163, 184, 0.25);
+}
+
+.floating-actions button {
+  font-family: var(--font-body);
+  font-size: 0.72rem;
+  font-weight: 600;
+  color: var(--ink);
+  background: rgba(30, 41, 59, 0.8);
+  border: 0;
+  border-radius: 999px;
+  padding: 6px 12px;
+  cursor: pointer;
+}
+
+.floating-actions button.hm-active {
+  background: linear-gradient(90deg, #10b981, #f59e0b, #ef4444);
+  color: #0a0a0a;
+}
+
+.lock-pill {
+  font-family: var(--font-mono);
+  font-size: 0.58rem;
+  color: #6ee7b7;
+  max-width: 220px;
+  overflow: hidden;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+  border-left: 1px solid rgba(148, 163, 184, 0.25);
+  padding-left: 10px;
+}
+
+.floating-label.glass {
+  background: rgba(8, 18, 28, 0.55);
+  backdrop-filter: blur(10px);
+  border: 1px solid rgba(147, 197, 253, 0.35);
+  border-radius: 10px;
+  padding: 8px 10px;
+}
+
+.hint-idle {
+  position: absolute;
+  z-index: 5;
+  left: 50%;
+  bottom: 28px;
+  transform: translateX(-50%);
+  font-size: 0.72rem;
+  color: var(--muted);
+  letter-spacing: 0.04em;
+  opacity: 0;
+  pointer-events: none;
+  transition: opacity 0.3s ease;
+}
+
+.hint-idle.show {
+  opacity: 0.55;
+}
+
+.app.r2 .config-lock-overlay,
+.app.r2 .honesty-strip {
+  display: none;
+}
+
+.app.r2 .toolbar .search-bar {
+  display: none;
+}
+
+.timeline-rail.surgery {
+  border-radius: 14px;
+}
+
+.maturity-grid {
+  margin: 0;
+  display: grid;
+  gap: 6px;
+}
+
+.maturity-grid > div {
+  display: grid;
+  grid-template-columns: 88px 1fr;
+  gap: 8px;
+  font-size: 0.72rem;
+  border-bottom: 1px solid rgba(120, 170, 200, 0.1);
+  padding-bottom: 4px;
+}
+
+.maturity-grid dt {
+  color: var(--muted);
+}
+
+.maturity-grid dd {
+  margin: 0;
+  font-family: var(--font-mono);
+  font-size: 0.62rem;
+  word-break: break-word;
+  color: #cbd5e1;
+}
+
+.storyboard-tag {
+  display: inline-block;
+  font-family: var(--font-mono);
+  font-size: 0.55rem;
+  letter-spacing: 0.08em;
+  color: #f59e0b;
+  border: 1px solid rgba(245, 158, 11, 0.4);
+  padding: 1px 5px;
+  margin-right: 6px;
+}
