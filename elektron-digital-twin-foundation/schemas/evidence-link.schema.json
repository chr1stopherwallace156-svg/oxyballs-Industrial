{
  "title": "EDTS Evidence Link",
  "type": "object",
  "required": [
    "evidence_link_id",
    "subject_id",
    "subject_type",
    "source_id",
    "relationship",
    "verification_status",
    "schema_version"
  ],
  "properties": {
    "evidence_link_id": {
      "type": "string",
      "pattern": "^EVL-[A-Z0-9-]+$"
    },
    "subject_id": {
      "type": "string",
      "minLength": 1
    },
    "subject_type": {
      "type": "string",
      "enum": [
        "COMPONENT_INSTANCE",
        "VEHICLE_INSTANCE",
        "CONFIGURATION",
        "GEOMETRY_ASSET",
        "OTHER"
      ]
    },
    "source_id": {
      "type": "string",
      "minLength": 1
    },
    "source_file_exists": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "relationship": {
      "type": "string",
      "enum": [
        "SUPPORTS_GEOMETRY",
        "SUPPORTS_DIMENSION",
        "SUPPORTS_MATERIAL",
        "SUPPORTS_APPLICABILITY",
        "CONTRADICTS",
        "NEUTRAL",
        "UNKNOWN",
        "NOT_EVALUATED"
      ]
    },
    "verification_status": {
      "type": "string",
      "enum": [
        "CANDIDATE",
        "AWAITING_FILE",
        "INGESTED",
        "NORMALIZED",
        "REJECTED",
        "UNKNOWN",
        "NOT_EVALUATED",
        "REQUIRES_EVIDENCE"
      ]
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:edts:schema:evidence-link:v1",
  "additionalProperties": false
}
