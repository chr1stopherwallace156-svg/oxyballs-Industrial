{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:edts:schema:research-mission:1.0.0",
  "title": "EDTS Research Mission",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mission_id",
    "id_immutable",
    "objective",
    "success_criteria",
    "completion_status",
    "bound_vehicle_instance_id",
    "bound_configuration_id"
  ],
  "properties": {
    "mission_id": {
      "type": "string",
      "pattern": "^MISN-[0-9]{6}$"
    },
    "id_immutable": {
      "type": "boolean",
      "const": true
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "objective": {
      "type": "string"
    },
    "target_gap_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "success_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_required": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "completion_status": {
      "type": "string",
      "enum": [
        "NOT_STARTED",
        "IN_PROGRESS",
        "BLOCKED",
        "COMPLETE",
        "CANCELLED"
      ]
    },
    "assigned_src_cand_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assigned_aid_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "bound_vehicle_instance_id": {
      "type": "string"
    },
    "bound_configuration_id": {
      "type": "string"
    },
    "research_sprint": {
      "type": [
        "string",
        "null"
      ]
    },
    "decision": {
      "type": [
        "string",
        "null"
      ]
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
