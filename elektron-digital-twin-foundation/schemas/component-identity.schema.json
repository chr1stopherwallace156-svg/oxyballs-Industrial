{
  "$id": "urn:edts:schema:component-identity:v1",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EDTS Component Identity Grammar",
  "description": "USS-IDENTITY rules for stable, collision-free component_id allocation across all platforms.",
  "type": "object",
  "required": ["grammar", "pattern", "families", "allocation_rules"],
  "properties": {
    "grammar": {
      "type": "string",
      "const": "CMP-{FAMILY}-{TOKEN}[-{QUALIFIER}]"
    },
    "pattern": {
      "type": "string",
      "description": "Regular expression for valid component_id values",
      "const": "^CMP-[A-Z0-9]+-[A-Z0-9]+(-[A-Z0-9]+)?$"
    },
    "examples": {
      "type": "array",
      "items": { "type": "string" },
      "examples": [
        "CMP-SD-044-L",
        "CMP-SD-FRAME-001",
        "CMP-AXL-M300"
      ]
    },
    "families": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["code", "description"],
        "properties": {
          "code": { "type": "string" },
          "description": { "type": "string" },
          "platform_agnostic": { "type": "boolean" }
        }
      }
    },
    "qualifiers": {
      "type": "object",
      "properties": {
        "side": {
          "type": "array",
          "items": { "type": "string", "enum": ["L", "R", "C"] }
        },
        "notes": {
          "type": "string",
          "description": "L/R/C for left/right/center. Omit when not applicable."
        }
      }
    },
    "allocation_rules": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "forbidden": {
      "type": "array",
      "items": { "type": "string" }
    },
    "aliases": {
      "description": "Deprecated IDs mapped to canonical IDs",
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
