{
  "title": "EDTS Vehicle Instance",
  "description": "Exact vehicle instance silo. No OEM literals in schema enums beyond structural states.",
  "type": "object",
  "required": [
    "vehicle_instance_id",
    "configuration_id",
    "instance_scope",
    "physical_asset_status",
    "schema_version"
  ],
  "properties": {
    "vehicle_instance_id": {
      "type": "string",
      "pattern": "^VEH-[A-Z0-9-]+$"
    },
    "configuration_id": {
      "type": "string",
      "pattern": "^CFG-[A-Z0-9-]+$"
    },
    "instance_scope": {
      "type": "string",
      "enum": [
        "CONFIGURATION_REFERENCE",
        "PHYSICAL_ASSET",
        "UNKNOWN",
        "NOT_EVALUATED"
      ]
    },
    "physical_asset_status": {
      "type": "string",
      "enum": [
        "NOT_ASSIGNED",
        "ASSIGNED",
        "INTAKE_PENDING",
        "UNKNOWN",
        "NOT_EVALUATED"
      ]
    },
    "vin": {
      "type": [
        "string",
        "null"
      ]
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:edts:schema:vehicle-instance:v1",
  "additionalProperties": false
}
