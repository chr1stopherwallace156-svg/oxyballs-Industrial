{
  "title": "ReusableComponentDefinition",
  "description": "Optional reusable component definition. Exists as empty candidate until interchangeability is independently verified. Similarity does not establish applicability.",
  "type": "object",
  "required": [
    "reusable_component_definition_id",
    "definition_status",
    "interchangeability_status",
    "schema_version"
  ],
  "properties": {
    "reusable_component_definition_id": {
      "type": "string",
      "minLength": 1
    },
    "canonical_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "definition_status": {
      "type": "string",
      "enum": [
        "EMPTY_CANDIDATE",
        "PARTIAL",
        "ACTIVE",
        "DEPRECATED",
        "REJECTED"
      ]
    },
    "interchangeability_status": {
      "type": "string",
      "enum": [
        "NOT_EVALUATED",
        "DISCOVERY_ONLY",
        "PROVEN",
        "REJECTED"
      ]
    },
    "proven_vehicle_instance_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Populated only after independent verification per exact vehicle. Empty for EMPTY_CANDIDATE."
    },
    "cross_vehicle_comparison_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:edts:schema:reusable-component-definition:v1",
  "additionalProperties": false
}
