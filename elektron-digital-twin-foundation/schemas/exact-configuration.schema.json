{
  "title": "EDTS Exact Configuration",
  "description": "Exact configuration silo with RFC 8785-style fingerprint. Schema contains no manufacturer literals.",
  "type": "object",
  "required": [
    "cab_to_axle_mm",
    "cab_type",
    "configuration_fingerprint",
    "configuration_id",
    "drivetrain",
    "fingerprint_status",
    "fingerprint_version",
    "manufacturer",
    "model",
    "model_year",
    "rear_wheel_configuration",
    "schema_version",
    "vehicle_type",
    "wheelbase_mm"
  ],
  "properties": {
    "configuration_id": {
      "type": "string",
      "pattern": "^CFG-[A-Z0-9-]+$"
    },
    "manufacturer": {
      "type": "string",
      "minLength": 1
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "model_year": {
      "type": "integer",
      "minimum": 1900
    },
    "vehicle_type": {
      "type": "string",
      "minLength": 1
    },
    "cab_type": {
      "type": "string",
      "minLength": 1
    },
    "drivetrain": {
      "type": "string",
      "minLength": 1
    },
    "rear_wheel_configuration": {
      "type": "string",
      "minLength": 1
    },
    "wheelbase_mm": {
      "type": "number"
    },
    "cab_to_axle_mm": {
      "type": "number"
    },
    "series": {
      "type": [
        "string",
        "null"
      ]
    },
    "configuration_fingerprint": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      ],
      "description": "null when fingerprint_status is NOT_COMPUTED; otherwise full sha256:hex64"
    },
    "fingerprint_version": {
      "type": "integer",
      "const": 1
    },
    "inheritance_status": {
      "type": "string",
      "const": "NONE"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    },
    "fingerprint_status": {
      "type": "string",
      "enum": [
        "NOT_COMPUTED",
        "COMPUTED",
        "INVALID"
      ]
    },
    "fingerprint_identity_object": {
      "type": [
        "object",
        "null"
      ]
    },
    "fingerprint_canonical_jcs": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:edts:schema:exact-configuration:v1",
  "additionalProperties": false
}
