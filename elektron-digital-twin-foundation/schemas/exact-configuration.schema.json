{
  "title": "ExactConfiguration",
  "description": "Exact vehicle configuration. Each cab, drivetrain, wheelbase, and CA value is a distinct configuration \u2014 no ranges, no inheritance.",
  "type": "object",
  "required": [
    "cab",
    "cab_to_axle",
    "configuration_fingerprint",
    "configuration_id",
    "drivetrain",
    "fingerprint_algorithm",
    "inheritance_status",
    "rear_wheel_configuration",
    "schema_version",
    "vehicle_instance_id",
    "wheelbase"
  ],
  "properties": {
    "configuration_id": {
      "type": "string",
      "minLength": 1
    },
    "vehicle_instance_id": {
      "type": "string",
      "minLength": 1
    },
    "cab": {
      "type": "string",
      "minLength": 1
    },
    "body_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "drivetrain": {
      "type": "string",
      "minLength": 1
    },
    "rear_wheel_configuration": {
      "type": "string",
      "minLength": 1
    },
    "wheelbase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "unit"
      ],
      "properties": {
        "value": {
          "type": "number"
        },
        "unit": {
          "type": "string",
          "enum": [
            "in",
            "mm"
          ]
        }
      }
    },
    "cab_to_axle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "unit"
      ],
      "properties": {
        "value": {
          "type": "number"
        },
        "unit": {
          "type": "string",
          "enum": [
            "in",
            "mm"
          ]
        }
      }
    },
    "series": {
      "type": [
        "string",
        "null"
      ]
    },
    "inheritance_status": {
      "type": "string",
      "const": "NONE",
      "description": "Exact configurations never inherit from related platforms."
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    },
    "configuration_fingerprint": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 hex digest of the canonical fingerprint string for this exact configuration."
    },
    "fingerprint_algorithm": {
      "type": "string",
      "const": "EDTS_CFG_FINGERPRINT_SHA256_V1"
    },
    "fingerprint_canonical_string": {
      "type": [
        "string",
        "null"
      ],
      "description": "Optional audit copy of the canonical string that was hashed. Dataset-only; never copied across vehicles."
    },
    "fingerprint_axes": {
      "type": "object",
      "additionalProperties": false,
      "description": "Physical attribute axes that feed the fingerprint. All axes are exact \u2014 never ranges.",
      "properties": {
        "model_year": {
          "type": [
            "integer",
            "null"
          ]
        },
        "manufacturer": {
          "type": [
            "string",
            "null"
          ]
        },
        "model": {
          "type": [
            "string",
            "null"
          ]
        },
        "vehicle_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "cab": {
          "type": [
            "string",
            "null"
          ]
        },
        "body_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "drivetrain": {
          "type": [
            "string",
            "null"
          ]
        },
        "rear_wheel_configuration": {
          "type": [
            "string",
            "null"
          ]
        },
        "wheelbase_in": {
          "type": [
            "number",
            "null"
          ]
        },
        "cab_to_axle_in": {
          "type": [
            "number",
            "null"
          ]
        },
        "series": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:edts:schema:exact-configuration:v1",
  "additionalProperties": false
}
