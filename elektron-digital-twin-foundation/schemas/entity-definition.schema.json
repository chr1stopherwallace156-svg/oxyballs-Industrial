{
  "title": "EntityDefinition",
  "description": "Universal entity definition. Contains no vehicle-specific facts.",
  "type": "object",
  "required": [
    "entity_definition_id",
    "entity_type",
    "canonical_name",
    "schema_version"
  ],
  "properties": {
    "entity_definition_id": {
      "type": "string",
      "minLength": 1
    },
    "entity_type": {
      "type": "string",
      "enum": [
        "COMPONENT",
        "ASSEMBLY",
        "MATERIAL",
        "SYSTEM_TEMPLATE",
        "OTHER"
      ]
    },
    "canonical_name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "lifecycle_status": {
      "type": "string",
      "enum": [
        "DISCOVERED",
        "REGISTERED",
        "CANDIDATE",
        "ACTIVE",
        "DEPRECATED",
        "REJECTED",
        "UNKNOWN",
        "NOT_EVALUATED"
      ]
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://edts.local/schemas/entity-definition.schema.json",
  "additionalProperties": false
}
