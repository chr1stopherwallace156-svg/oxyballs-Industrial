{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:edts:schema:entity-definition:v1",
  "title": "EntityDefinition",
  "description": "Universal entity definition. Contains no vehicle-specific facts. Kernel v1.0.0-rc1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entity_id",
    "entity_type"
  ],
  "properties": {
    "entity_id": {
      "type": "string",
      "minLength": 1
    },
    "entity_type": {
      "type": "string",
      "enum": [
        "COMPONENT",
        "VEHICLE",
        "ASSEMBLY"
      ]
    },
    "canonical_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "lifecycle_status": {
      "type": "string",
      "enum": [
        "DISCOVERED",
        "REGISTERED",
        "CANDIDATE",
        "ACTIVE",
        "DEPRECATED",
        "REJECTED",
        "UNKNOWN",
        "NOT_EVALUATED"
      ]
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
