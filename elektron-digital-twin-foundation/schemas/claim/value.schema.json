{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EDTS_Claim_Value_Representation",
  "type": "object",
  "properties": {
    "representation_format": {
      "type": "string",
      "enum": [
        "SCALAR",
        "RANGE",
        "VECTOR",
        "MATRIX",
        "ENUM",
        "BOOLEAN",
        "TEXT",
        "ENTITY_REFERENCE",
        "RELATIONSHIP",
        "TIME_SERIES_REFERENCE"
      ]
    },
    "nominal_value": {
      "type": ["number", "string", "boolean", "array", "null"]
    },
    "minimum_allowed": { "type": "number" },
    "maximum_allowed": { "type": "number" }
  },
  "required": ["representation_format", "nominal_value"],
  "additionalProperties": false
}
