{
  "$id": "urn:edts:schema:kernel:assembly-relationship:v1",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ASSEMBLY_RELATIONSHIP_SCHEMA_PROPOSAL",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "relationship_id",
    "subject_entity_id",
    "predicate",
    "object_entity_id"
  ],
  "properties": {
    "relationship_id": { "type": "string" },
    "subject_entity_id": { "type": "string" },
    "predicate": {
      "type": "string",
      "enum": ["IS_PART_OF", "ATTACHES_TO", "REPLACES", "COMPATIBLE_WITH"]
    },
    "object_entity_id": { "type": "string" },
    "configuration_id": { "type": ["string", "null"] }
  },
  "examples": [
    {
      "relationship_id": "REL-00001",
      "subject_entity_id": "CMP-FORD-SD-DOOR-FL-001",
      "predicate": "IS_PART_OF",
      "object_entity_id": "ASM-FORD-SD-CAB-001",
      "configuration_id": "CFG-F450-REG-2019"
    }
  ]
}
