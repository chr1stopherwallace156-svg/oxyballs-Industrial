{
  "$id": "urn:edts:schema:kernel:evidence-link:v1",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EVIDENCE_LINK_SCHEMA_PROPOSAL",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "evidence_link_id",
    "entity_id",
    "source_id",
    "relationship",
    "verification_status"
  ],
  "properties": {
    "evidence_link_id": { "type": "string" },
    "entity_id": { "type": "string" },
    "source_id": { "type": "string" },
    "relationship": {
      "type": "string",
      "enum": [
        "SUPPORTS_GEOMETRY",
        "SUPPORTS_DIMENSION",
        "SUPPORTS_MATERIAL",
        "SUPPORTS_APPLICABILITY",
        "CONTRADICTS",
        "NEUTRAL"
      ]
    },
    "verification_status": {
      "type": "string",
      "enum": [
        "CANDIDATE",
        "AWAITING_FILE",
        "INGESTED",
        "NORMALIZED",
        "CONFIGURATION_MATCHED",
        "REJECTED"
      ]
    },
    "notes": { "type": "string" },
    "file_exists": { "type": ["boolean", "null"] },
    "page_evidence_asserted": { "type": "boolean" }
  },
  "examples": [
    {
      "evidence_link_id": "EVL-00001",
      "entity_id": "CMP-FORD-SD-DOOR-FL-001",
      "source_id": "SRC-BBAS-2019-SD",
      "relationship": "SUPPORTS_GEOMETRY",
      "verification_status": "CANDIDATE"
    }
  ]
}
