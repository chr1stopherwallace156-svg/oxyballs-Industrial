{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:edts:schema:asset-intelligence-passport:1.1.0",
  "title": "EDTS Asset Intelligence Passport (AID)",
  "description": "Non-kernel research/ops schema. Every discovered internet asset gets a passport. Listing claims \u2260 evaluated truth. Completeness ordinals are authoritative for pre-bytes triage (Hard Rule 5). Optional 0\u20131 score_claims are RESEARCH_CLAIM / LISTING_CLAIM only until LOCAL_BYTES_PARSED. Frozen kernel schemas are untouched.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "asset_id",
    "id_immutable",
    "schema_version",
    "authority_status",
    "source",
    "geometry_types",
    "exact_configuration_match",
    "completeness",
    "usefulness",
    "license",
    "price",
    "lifecycle",
    "component_coverage",
    "known_deficiencies",
    "evidence_links",
    "bound_vehicle_instance_id",
    "bound_configuration_id"
  ],
  "properties": {
    "asset_id": {
      "type": "string",
      "pattern": "^AID-[0-9]{6}$",
      "description": "Immutable Asset Intelligence handle"
    },
    "id_immutable": {
      "type": "boolean",
      "const": true
    },
    "schema_version": {
      "type": "string",
      "enum": [
        "1.0.0",
        "1.1.0"
      ]
    },
    "authority_status": {
      "type": "string",
      "enum": [
        "RESEARCH_OPERATIONAL",
        "ILLUSTRATIVE_ONLY",
        "SUPERSEDED"
      ]
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Legacy IDs: EDTS-CAND-*, CAND-*, SRC-CAND-*, ASSET-*"
    },
    "title": {
      "type": "string"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "platform",
        "url",
        "url_status"
      ],
      "properties": {
        "platform": {
          "type": "string"
        },
        "publisher": {
          "type": [
            "string",
            "null"
          ]
        },
        "url": {
          "type": [
            "string",
            "null"
          ]
        },
        "url_status": {
          "type": "string",
          "enum": [
            "NOT_RECORDED",
            "URL_RECORDED",
            "URL_FETCH_CONFIRMED",
            "CATEGORY_OR_SEARCH_SURFACE_NOT_SKU_SPECIFIC",
            "MARKETPLACE_ID_ONLY",
            "INCOMPLETE_SLUG_DO_NOT_INVENT",
            "BROKEN_OR_UNREACHABLE"
          ]
        },
        "marketplace_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "access_condition": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "vehicle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reported_make": {
          "type": [
            "string",
            "null"
          ]
        },
        "reported_model": {
          "type": [
            "string",
            "null"
          ]
        },
        "reported_year_range": {
          "type": [
            "string",
            "null"
          ]
        },
        "reported_body": {
          "type": [
            "string",
            "null"
          ]
        },
        "listing_claim_summary": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reported_cab": {
          "type": [
            "string",
            "null"
          ]
        },
        "reported_ca_in": {
          "type": [
            "number",
            "null"
          ]
        },
        "reported_wheelbase_in": {
          "type": [
            "number",
            "null"
          ]
        },
        "reported_drivetrain": {
          "type": [
            "string",
            "null"
          ]
        },
        "reported_rear_wheels": {
          "type": [
            "string",
            "null"
          ]
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "exact_configuration_match": {
      "type": "string",
      "enum": [
        "UNKNOWN",
        "NONE",
        "PLATFORM_BAND",
        "VISUAL_GENERATION",
        "EXTERIOR_PROPORTION_CANDIDATE",
        "CLAIMED_EXACT_UNVERIFIED",
        "COMPARISON_REFERENCE",
        "CONFIGURATION_MATCHED"
      ],
      "description": "CONFIGURATION_MATCHED only after Hard Rule 4 + HR-EVI \u2014 never from listing title alone"
    },
    "geometry_types": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "STEP",
          "PARASOLID",
          "SLDPRT",
          "FBX",
          "OBJ",
          "GLB",
          "GLTF",
          "BLEND",
          "DAE",
          "STL",
          "IGES",
          "SVG",
          "EPS",
          "AI",
          "CDR",
          "SCAN",
          "PHOTOGRAMMETRY",
          "VECTOR_2D",
          "UNKNOWN",
          "OTHER"
        ]
      }
    },
    "completeness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exterior",
        "interior",
        "mechanical",
        "electrical",
        "hierarchy_quality",
        "mesh_separation",
        "topology_quality",
        "evaluation_basis"
      ],
      "properties": {
        "exterior": {
          "$ref": "#/$defs/ordinal"
        },
        "interior": {
          "$ref": "#/$defs/ordinal"
        },
        "mechanical": {
          "$ref": "#/$defs/ordinal"
        },
        "electrical": {
          "$ref": "#/$defs/ordinal"
        },
        "hierarchy_quality": {
          "$ref": "#/$defs/ordinal"
        },
        "mesh_separation": {
          "$ref": "#/$defs/ordinal"
        },
        "topology_quality": {
          "$ref": "#/$defs/ordinal"
        },
        "evaluation_basis": {
          "type": "string",
          "enum": [
            "LISTING_ONLY",
            "PARTIAL_PREVIEW",
            "LOCAL_BYTES_PARSED",
            "NOT_EVALUATED"
          ]
        }
      }
    },
    "usefulness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "engineering",
        "visual"
      ],
      "properties": {
        "engineering": {
          "$ref": "#/$defs/ordinal"
        },
        "visual": {
          "$ref": "#/$defs/ordinal"
        }
      }
    },
    "license": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "UNKNOWN",
            "REQUIRES_COUNSEL_REVIEW",
            "COMMERCIAL_PURCHASE",
            "ROYALTY_FREE_CLAIMED",
            "OPEN_COMMUNITY_CLAIMED",
            "OEM_RESTRICTED",
            "REJECTED"
          ]
        },
        "terms_summary": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "price": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "UNKNOWN",
            "FREE_CLAIMED",
            "PAID",
            "NOT_APPLICABLE"
          ]
        },
        "amount_usd": {
          "type": [
            "number",
            "null"
          ]
        },
        "currency_note": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "discovered",
        "acquired",
        "parsed",
        "verified"
      ],
      "properties": {
        "discovered": {
          "type": "boolean"
        },
        "acquired": {
          "type": "string",
          "enum": [
            "NOT_ACQUIRED",
            "ACQUIRED",
            "QUARANTINED",
            "REJECTED"
          ]
        },
        "parsed": {
          "type": "string",
          "enum": [
            "NOT_EXECUTED",
            "PARTIAL",
            "COMPLETE",
            "FAILED"
          ]
        },
        "verified": {
          "type": "string",
          "enum": [
            "NOT_EXECUTED",
            "LISTING_URL_CONFIRMED",
            "BYTES_HASHED",
            "CONFIGURATION_MATCHED",
            "REJECTED"
          ]
        }
      }
    },
    "component_coverage": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target",
          "presence"
        ],
        "properties": {
          "target": {
            "type": "string"
          },
          "presence": {
            "type": "string",
            "enum": [
              "UNKNOWN",
              "ABSENT",
              "CLAIMED",
              "SHELL_ONLY",
              "PARTIAL",
              "SEPARABLE_CLAIMED",
              "VERIFIED_PRESENT"
            ]
          },
          "notes": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "known_deficiencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_links": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "ref"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "AJR",
              "ASSEMBLY_HUB",
              "CLAIM",
              "COMPONENT_PASSPORT",
              "EVALUATION",
              "LANE_A_CATALOG",
              "LISTING_URL",
              "LOCAL_BYTES",
              "OTHER",
              "RELATED_LISTING",
              "SPRINT",
              "SRC_CAND",
              "SUPPLIER_DOC"
            ]
          },
          "ref": {
            "type": "string"
          },
          "note": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "bound_vehicle_instance_id": {
      "type": "string"
    },
    "bound_configuration_id": {
      "type": "string"
    },
    "configuration_fingerprint": {
      "type": [
        "string",
        "null"
      ]
    },
    "related_asset_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^AID-[0-9]{6}$"
      }
    },
    "maps_to_src_cand": {
      "type": [
        "string",
        "null"
      ]
    },
    "maps_to_candidate_asset_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "edts_role": {
      "type": "string",
      "enum": [
        "ACQUISITION_INPUT",
        "ASSEMBLY_HUB_INPUT",
        "CAD_CANDIDATE",
        "COMPARISON_REFERENCE",
        "PROFILE_REFERENCE",
        "REJECTED_INPUT",
        "SUPPLIER_CAD_CANDIDATE",
        "UNKNOWN",
        "VISUAL_CANDIDATE"
      ],
      "description": "How EDTS should treat this asset \u2014 never 'the answer' until verified"
    },
    "research_sprint": {
      "type": [
        "string",
        "null"
      ]
    },
    "decision": {
      "type": [
        "string",
        "null"
      ]
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "score_claims": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional 0\u20131 claims from research narrative/listings \u2014 NOT Hard Rule 5 engineering confidence; not EVALUATED without bytes",
      "properties": {
        "exterior_completeness": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status"
          ],
          "properties": {
            "value": {
              "type": [
                "number",
                "null"
              ],
              "minimum": 0,
              "maximum": 1
            },
            "status": {
              "type": "string",
              "enum": [
                "NOT_EXECUTED",
                "RESEARCH_CLAIM",
                "LISTING_CLAIM",
                "EVALUATED",
                "REJECTED"
              ]
            },
            "basis": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "interior_completeness": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status"
          ],
          "properties": {
            "value": {
              "type": [
                "number",
                "null"
              ],
              "minimum": 0,
              "maximum": 1
            },
            "status": {
              "type": "string",
              "enum": [
                "NOT_EXECUTED",
                "RESEARCH_CLAIM",
                "LISTING_CLAIM",
                "EVALUATED",
                "REJECTED"
              ]
            },
            "basis": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "mechanical_completeness": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status"
          ],
          "properties": {
            "value": {
              "type": [
                "number",
                "null"
              ],
              "minimum": 0,
              "maximum": 1
            },
            "status": {
              "type": "string",
              "enum": [
                "NOT_EXECUTED",
                "RESEARCH_CLAIM",
                "LISTING_CLAIM",
                "EVALUATED",
                "REJECTED"
              ]
            },
            "basis": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "electrical_completeness": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status"
          ],
          "properties": {
            "value": {
              "type": [
                "number",
                "null"
              ],
              "minimum": 0,
              "maximum": 1
            },
            "status": {
              "type": "string",
              "enum": [
                "NOT_EXECUTED",
                "RESEARCH_CLAIM",
                "LISTING_CLAIM",
                "EVALUATED",
                "REJECTED"
              ]
            },
            "basis": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "engineering_usefulness": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status"
          ],
          "properties": {
            "value": {
              "type": [
                "number",
                "null"
              ],
              "minimum": 0,
              "maximum": 1
            },
            "status": {
              "type": "string",
              "enum": [
                "NOT_EXECUTED",
                "RESEARCH_CLAIM",
                "LISTING_CLAIM",
                "EVALUATED",
                "REJECTED"
              ]
            },
            "basis": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "visual_usefulness": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status"
          ],
          "properties": {
            "value": {
              "type": [
                "number",
                "null"
              ],
              "minimum": 0,
              "maximum": 1
            },
            "status": {
              "type": "string",
              "enum": [
                "NOT_EXECUTED",
                "RESEARCH_CLAIM",
                "LISTING_CLAIM",
                "EVALUATED",
                "REJECTED"
              ]
            },
            "basis": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        }
      }
    },
    "supplier_hub": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "supplier_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "supplier_component_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "reported_oem_part_number": {
          "type": [
            "string",
            "null"
          ]
        },
        "documentation_types_hunt": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "lane": {
          "type": "string",
          "enum": [
            "LANE_SUPPLIER",
            "LANE_OEM",
            "LANE_MARKETPLACE",
            "LANE_MIXED"
          ]
        }
      }
    },
    "assembly_hub": {
      "type": [
        "string",
        "null"
      ],
      "description": "Logical assembly hub under deconstructed sourcing (e.g. REAR_AXLE, FL_DOOR, STEERING)"
    },
    "ajr_id": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^AJR-[0-9]{6}$"
    },
    "match_tri_state": {
      "type": "object",
      "additionalProperties": false,
      "description": "Operator-facing true|false|conditional mapping onto exact_configuration_match enum",
      "properties": {
        "value": {
          "type": "string",
          "enum": [
            "true",
            "false",
            "conditional",
            "unknown"
          ]
        },
        "crossover_validation_requirements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "component_coverage_lists": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "present": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "ordinal": {
      "type": "string",
      "enum": [
        "NOT_EVALUATED",
        "NOT_APPLICABLE",
        "NONE",
        "LOW",
        "PARTIAL",
        "HIGH"
      ],
      "description": "Qualitative ordinal only \u2014 not a confidence percentage (Hard Rule 5)"
    }
  }
}
