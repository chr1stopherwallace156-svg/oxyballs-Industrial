{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elektron.local/contracts/package-inventory/1.0.0",
  "title": "PackageInventory",
  "version": "1.0.0",
  "owner": "elektron-capture-ios",
  "contract_ownership": "JOINT_CAPTURE_EDTS",
  "status": "DRAFT",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "package_format_version",
    "package_id",
    "entries"
  ],
  "properties": {
    "schema_id": { "const": "PackageInventory" },
    "schema_version": { "const": "1.0.0" },
    "package_format_version": { "const": "1.0.0" },
    "package_id": { "type": "string", "minLength": 1 },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "byte_size", "sha256"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?!/)(?!.*\\.\\./)[A-Za-z0-9._/-]+$"
          },
          "byte_size": { "type": "integer", "minimum": 0 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "notes": { "type": "array", "items": { "type": "string" } }
  }
}
