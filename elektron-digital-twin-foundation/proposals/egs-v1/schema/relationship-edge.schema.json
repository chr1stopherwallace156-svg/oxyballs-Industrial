{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:edts:proposal:egs-v1:relationship-edge:1.0.0",
  "title": "EGS-v1 Relationship Edge (Proposal)",
  "description": "Non-kernel proposal schema. Does not modify frozen assembly-relationship.schema.json. Endpoints MUST be component-instance IDs (CMPINST-*), never AID/asset IDs. Engineering property values (torque, fastener counts, connectors, removal steps) require verified evidence links — omit when absent.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "edge_id",
    "schema_version",
    "relationship_class",
    "relationship_type",
    "source_component_instance_id",
    "target_component_instance_id",
    "directionality",
    "vehicle_instance_id",
    "configuration_id",
    "lifecycle_status",
    "applicability",
    "property_evidence_links"
  ],
  "properties": {
    "edge_id": {
      "type": "string",
      "pattern": "^REL-EGS-[0-9]{6}$"
    },
    "schema_version": { "type": "string", "const": "egs-v1.0.0-proposal" },
    "relationship_class": {
      "type": "string",
      "enum": [
        "MECHANICAL_STRUCTURAL",
        "ELECTRICAL_FLUID",
        "KINEMATIC_GEOMETRIC",
        "PROCEDURAL"
      ]
    },
    "relationship_type": {
      "type": "string",
      "enum": [
        "BOLTED_TO",
        "MOUNTED_TO",
        "HINGES_ON",
        "SUPPORTS",
        "OVERLAPS",
        "CONTAINS",
        "CONNECTED_TO",
        "ROUTES_THROUGH",
        "PASSES_BEHIND",
        "INTERFERES_WITH",
        "SLIDES_ALONG",
        "BLOCKS_REMOVAL_OF"
      ]
    },
    "source_component_instance_id": {
      "type": "string",
      "pattern": "^CMPINST-[A-Z0-9-]+$",
      "description": "Exact component-instance ID — never AID-* or marketplace asset IDs"
    },
    "target_component_instance_id": {
      "type": "string",
      "pattern": "^CMPINST-[A-Z0-9-]+$"
    },
    "directionality": {
      "type": "string",
      "enum": ["FORWARD", "BACKWARD", "BIDIRECTIONAL"]
    },
    "vehicle_instance_id": {
      "type": "string",
      "pattern": "^VEH-[A-Z0-9-]+$"
    },
    "configuration_id": {
      "type": "string",
      "pattern": "^CFG-[A-Z0-9-]+$"
    },
    "configuration_fingerprint": { "type": ["string", "null"] },
    "lifecycle_status": {
      "type": "string",
      "enum": [
        "CANDIDATE_UNVERIFIED",
        "RESEARCH_CLAIM",
        "DOCUMENT_SUPPORTED",
        "VERIFIED",
        "REJECTED",
        "SUPERSEDED"
      ]
    },
    "applicability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope"],
      "properties": {
        "scope": {
          "type": "string",
          "enum": ["EXACT_CONFIGURATION", "PLATFORM_BAND", "SYNTHETIC_FIXTURE", "UNKNOWN"]
        },
        "cab_config": { "type": ["string", "null"] },
        "option_codes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": { "type": ["string", "null"] }
      }
    },
    "property_evidence_links": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["property_key", "evidence_status"],
        "properties": {
          "property_key": {
            "type": "string",
            "enum": [
              "relationship_existence",
              "directionality",
              "torque_specification",
              "fastener_specification",
              "connector_interface",
              "removal_precedence",
              "kinematic_clearance",
              "routing_path",
              "other"
            ]
          },
          "evidence_link_id": {
            "type": ["string", "null"],
            "pattern": "^EVL-[A-Z0-9-]+$"
          },
          "src_cand_id": { "type": ["string", "null"] },
          "evidence_status": {
            "type": "string",
            "enum": [
              "ABSENT",
              "CLAIMED_UNHASHED",
              "HASHED_UNAPPLIED",
              "BOUND",
              "REJECTED"
            ]
          },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "engineering_properties": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "description": "Omit or null unless verified evidence exists. Proposal validators reject populated torque/fastener/connector/removal fields when evidence_status is not BOUND.",
      "properties": {
        "torque_nm": { "type": ["number", "null"] },
        "torque_tolerance": { "type": ["string", "null"] },
        "fastener_id": { "type": ["string", "null"] },
        "fastener_count": { "type": ["integer", "null"] },
        "connector_description": { "type": ["string", "null"] },
        "removal_precedence_index": { "type": ["integer", "null"] }
      }
    },
    "aliases": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
